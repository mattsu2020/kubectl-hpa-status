# EditorConfig helps maintain consistent coding style across editors and IDEs.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Go follows gofmt: tabs, no trailing whitespace, LF endings.
[*.go]
indent_style = tab
indent_size = 4

# YAML, JSON, and Markdown use two-space indentation.
[*.{yml,yaml,json}]
indent_size = 2

[*.md]
indent_size = 2
# Markdown trailing whitespace can be significant (hard line break = two
# trailing spaces), so leave it intact.
trim_trailing_whitespace = false

[*.{sh,bash}]
indent_size = 2

# Makefiles require tab indentation.
[Makefile]
indent_style = tab
